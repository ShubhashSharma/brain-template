{
  "commitMessage": "vault: {{date}}",
  "commitDateFormat": "YYYY-MM-DD HH:mm:ss",
  "autoSaveInterval": 0,
  "autoPushInterval": 0,
  "autoPullInterval": 15,
  "autoCommitAndSync": 30,
  "autoCommitAndSyncOnlyOnLooseChanges": true,
  "syncMethod": "merge",
  "disablePush": false,
  "pullBeforePush": true,
  "disablePopups": true,
  "disableNotifications": true,
  "showStatusBar": true,
  "updateSubmodules": false,
  "submoduleRecurseCheckout": false,
  "gitReady": true
}
